  "description": "My personal portfolio",
  "author": {
    "name": "Ali Heydari",
    "email": "hi+packagejson@ali4heydari.tech"
  },
  "keywords": [
    "Nextjs",
    "typescript",
    "tailwindcss"
  ],
  "bugs": {
    "url": "https://github.com/ali4heydari/ali4heydari.github.io/issues"
